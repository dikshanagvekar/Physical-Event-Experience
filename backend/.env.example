# Backend environment variables
# Copy this to .env and fill in your values
# NEVER commit .env to git

# Required
GEMINI_API_KEY=AIza...

# Firebase Admin SDK
# Path to your downloaded service account JSON key
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
FIREBASE_DATABASE_URL=https://YOUR_PROJECT-default-rtdb.asia-southeast1.firebasedatabase.app

# Optional — CricAPI for live scores (free tier at cricapi.com)
CRICAPI_KEY=YOUR_CRICAPI_KEY

# Server config (Cloud Run sets PORT automatically)
PORT=8080
